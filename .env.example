VOICE_AGENT_MODE=mock
VOICE_AGENT_HOST=0.0.0.0
VOICE_AGENT_PORT=8000
# Optional deployment fallback used by some platforms. VOICE_AGENT_PORT wins if both are set.
PORT=
VOICE_AGENT_WS_PING_INTERVAL=30
VOICE_AGENT_WS_PING_TIMEOUT=120
VOICE_AGENT_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Required only when VOICE_AGENT_MODE=live.
DEEPGRAM_API_KEY=
GROQ_API_KEY=
CARTESIA_API_KEY=

# Live-mode tuning placeholders.
DEEPGRAM_MODEL=nova-3
DEEPGRAM_ENDPOINTING_MS=220
DEEPGRAM_UTTERANCE_END_MS=1000
VOICE_AGENT_PARTIAL_IDLE_FINALIZE_MS=1000
VOICE_AGENT_INTENT_INFERENCE_ENABLED=true
VOICE_AGENT_CARTESIA_SPEECH_DIRECTOR_ENABLED=true
VOICE_AGENT_CARTESIA_SSML_ENABLED=true
VOICE_AGENT_CARTESIA_EMOTION_TAGS_ENABLED=false
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.7
CARTESIA_MODEL=sonic-3
CARTESIA_SPEED=1.2
CARTESIA_SAMPLE_RATE=16000
CARTESIA_VERSION=2026-03-01
CARTESIA_VOICE_ID=
VOICE_AGENT_PERSONA="You are a concise, warm voice on an ambiguous open phone call. Sound present and spoken, as if you are still on the line with the caller. Keep replies brief, natural, and phone-call appropriate. Never sound like a web chat assistant."

# Browser-local ambience. This is played only in the client output path, never sent to STT.
VOICE_AGENT_AMBIENCE_ENABLED=true
VOICE_AGENT_AMBIENCE_SCENE=room_line
VOICE_AGENT_AMBIENCE_VOLUME=0.035

# Proactive conversation tuning. "auto" enables mock/dev and requires explicit opt-in for live mode.
VOICE_AGENT_PROACTIVE_ENABLED=auto
# Optional overrides. Defaults are mode-aware: mock/demo nudges after 5s; live opt-in waits 30s and prompts once.
# VOICE_AGENT_PROACTIVE_GREETING_DELAY_MS=500
# VOICE_AGENT_PROACTIVE_SILENCE_TIMEOUT_MS=30000
# VOICE_AGENT_PROACTIVE_REPEAT_COOLDOWN_MS=60000
# VOICE_AGENT_PROACTIVE_MAX_CONSECUTIVE_PROMPTS=1
# VOICE_AGENT_PROACTIVE_FAILURE_BACKOFF_THRESHOLD=2
# VOICE_AGENT_PROACTIVE_FAILURE_BACKOFF_MS=30000
VOICE_AGENT_PROACTIVE_CONTEXTUAL_FOLLOWUPS_ENABLED=true
