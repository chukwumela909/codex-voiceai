VOICE_AGENT_MODE=mock
VOICE_AGENT_HOST=0.0.0.0
VOICE_AGENT_PORT=8000
# Optional deployment fallback used by some platforms. VOICE_AGENT_PORT wins if both are set.
PORT=
VOICE_AGENT_WS_PING_INTERVAL=30
VOICE_AGENT_WS_PING_TIMEOUT=120
VOICE_AGENT_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Required only when VOICE_AGENT_MODE=live.
DEEPGRAM_API_KEY=
GROQ_API_KEY=
CARTESIA_API_KEY=

# Live-mode tuning placeholders.
DEEPGRAM_MODEL=nova-3
DEEPGRAM_ENDPOINTING_MS=300
DEEPGRAM_UTTERANCE_END_MS=1000
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.7
CARTESIA_MODEL=sonic-3
CARTESIA_SAMPLE_RATE=16000
CARTESIA_VERSION=2026-03-01
CARTESIA_VOICE_ID=
VOICE_AGENT_PERSONA="You are a playful, vivid conversational voice agent. Keep replies concise, warm, and naturally spoken."
